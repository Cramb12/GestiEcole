# ============================================================
# Script de seed — variables (NE JAMAIS committer le vrai .env)
# Supabase > Project Settings > API
# ============================================================

# URL du projet (ex: https://xxxx.supabase.co)
SUPABASE_URL=https://xxxx.supabase.co

# Cle SERVICE ROLE (secrete !) — contourne la RLS pour creer les comptes.
# A utiliser UNIQUEMENT dans ce script local, jamais cote frontend.
SUPABASE_SERVICE_ROLE_KEY=collez_votre_cle_service_role_ici
