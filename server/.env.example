# ============================================================
# Configuration du serveur — Systeme de gestion scolaire RDC
# Copiez ce fichier en ".env" et remplissez les valeurs.
# ============================================================

# Port de l'API
PORT=5000

# Chaine de connexion PostgreSQL (Supabase)
# Supabase: Project Settings > Database > Connection string > URI
# Exemple: postgresql://postgres:VOTRE_MOT_DE_PASSE@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# Mettre "true" pour les bases hebergees (Supabase) qui exigent SSL
DB_SSL=true

# Secret pour signer les tokens JWT (mettez une longue chaine aleatoire)
JWT_SECRET=changez_moi_par_une_chaine_secrete_longue_et_aleatoire

# Duree de validite du token
JWT_EXPIRES_IN=7d

# Origine autorisee pour le frontend (CORS)
CLIENT_URL=http://localhost:5173
